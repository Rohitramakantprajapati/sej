APP_ENV=development
MAX_UPLOAD_MB=20
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000,http://127.0.0.1:8000

# Runtime guardrails
RATE_LIMIT_PER_MINUTE=120
SESSION_TTL_HOURS=24
MAX_IN_MEMORY_SESSIONS=64

# Optional: set a bearer token to require Authorization: Bearer <token>
APP_API_TOKEN=

# Production example values:
# APP_ENV=production
# MAX_UPLOAD_MB=20
# ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
